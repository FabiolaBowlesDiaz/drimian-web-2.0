---
import Section from './Section.astro';
import Button from './Button.astro';
import { Image } from 'astro:assets';
import logo from '../assets/images/drimian-logo.png';
---
<section
  data-theme="dark"
  id="hero"
  class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden text-[var(--section-text)]"
  style="background: linear-gradient(180deg, var(--color-navy) 0%, #0a0e1f 100%);"
>
  <!-- Content -->
  <div class="relative z-10 text-center px-6 md:px-12 max-w-3xl mx-auto">
    <Image
      src={logo}
      alt="Drimian - Dream with Intelligence"
      width={160}
      class="mx-auto mb-14 brightness-0 invert opacity-85"
    />
    <h1 class="text-[2rem] md:text-[2.5rem] lg:text-[2.85rem] font-bold font-heading leading-[1.1] tracking-tight mb-8 max-w-2xl mx-auto">
      ¿Estás construyendo lo que va a hacer próspera a tu empresa?
    </h1>
    <p class="text-base md:text-lg text-[var(--section-text-secondary)] mb-14 max-w-lg mx-auto leading-relaxed">
      10 preguntas. 3 minutos.<br class="hidden sm:inline" />
      Descubrí si estás empujando más fuerte — o cambiando lo que importa.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <button
        id="start-diagnostic"
        class="inline-flex items-center justify-center bg-orange text-white font-semibold rounded-xl px-10 py-4 text-base hover:bg-orange-hover transition-all duration-200 hover:shadow-[0_8px_24px_rgba(255,102,0,0.25)]"
      >
        Empezar el diagnóstico
      </button>
    </div>
    <script>
      document.getElementById('start-diagnostic')?.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('open-diagnostic'));
      });
    </script>
    <a
      href="#que-es-drimian"
      class="inline-block mt-12 text-[var(--section-text-secondary)] opacity-50 hover:opacity-80 text-sm transition-opacity duration-200"
    >
      O seguí leyendo ↓
    </a>
  </div>
</section>
