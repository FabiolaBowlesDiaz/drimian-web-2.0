---
// Nav component: scroll-triggered navigation
// NOTE: The nav-sentinel element must be placed in the PAGE (not here),
// right after the hero section. The sentinel triggers the IntersectionObserver
// that shows/hides this nav bar.
import { Image } from 'astro:assets';
import logo from '../assets/images/drimian-logo.png';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 -translate-y-full transition-transform duration-300 bg-navy/95 backdrop-blur-sm"
>
  <div class="max-w-5xl mx-auto px-6 md:px-12 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href={`${base}/`} class="flex items-center">
      <Image src={logo} alt="Drimian" height={32} class="h-8 w-auto brightness-0 invert" />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      <a href={`${base}/principios`} class="text-sm font-medium text-text-primary hover:text-orange transition-colors duration-200">
        Principios
      </a>
      <a href={`${base}/resultados`} class="text-sm font-medium text-text-primary hover:text-orange transition-colors duration-200">
        Resultados
      </a>
      <a href="#que-es-drimian" class="inline-flex items-center bg-orange text-white text-sm font-semibold rounded-md px-6 py-2.5 hover:bg-orange-hover transition-colors duration-200">
        Empezar diagnóstico
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="nav-hamburger"
      class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-text-primary transition-all duration-200"></span>
      <span class="block w-6 h-0.5 bg-text-primary transition-all duration-200"></span>
      <span class="block w-6 h-0.5 bg-text-primary transition-all duration-200"></span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div id="nav-mobile-menu" class="hidden md:hidden bg-navy/95 backdrop-blur-sm border-t border-border-dark px-6 pb-6 pt-4">
    <a href={`${base}/principios`} class="block text-sm font-medium text-text-primary hover:text-orange transition-colors duration-200 py-3">
      Principios
    </a>
    <a href={`${base}/resultados`} class="block text-sm font-medium text-text-primary hover:text-orange transition-colors duration-200 py-3">
      Resultados
    </a>
    <a href="#que-es-drimian" class="inline-flex items-center bg-orange text-white text-sm font-semibold rounded-md px-6 py-2.5 mt-3 hover:bg-orange-hover transition-colors duration-200">
      Empezar diagnóstico
    </a>
  </div>
</nav>

<script>
  // Scroll-triggered nav:
  // - Only shows when user scrolls DOWN past the hero
  // - Hides when user scrolls back UP into the hero area
  const nav = document.getElementById('main-nav');
  const sentinel = document.getElementById('nav-sentinel');

  if (nav && sentinel) {
    let lastScrollY = 0;
    let pastHero = false;

    const observer = new IntersectionObserver(
      ([entry]) => {
        pastHero = !entry.isIntersecting;
        // Always hide nav when hero/sentinel is visible
        if (entry.isIntersecting) {
          nav.classList.add('-translate-y-full');
        }
      },
      { threshold: 0 }
    );
    observer.observe(sentinel);

    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      const scrollingDown = currentScrollY > lastScrollY;

      if (pastHero && scrollingDown) {
        // Scrolling down past hero → show nav
        nav.classList.remove('-translate-y-full');
      } else if (!pastHero) {
        // Back in hero area → always hide
        nav.classList.add('-translate-y-full');
      }

      lastScrollY = currentScrollY;
    }, { passive: true });
  }

  // Mobile menu toggle
  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('nav-mobile-menu');
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburger.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
